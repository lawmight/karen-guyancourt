# Copy to .env.local and fill with your values.
# On Vercel: set these in Project → Settings → Environment Variables.

# === Access ===
# Query key for ?key=... and API routes (header: x-access-key)
KEY_TO_ACCESS_THE_SCRIPT=

# === API Keys ===
POSTMARK_API_KEY=
OPENROUTER_API_KEY=

# === Identity ===
YOUR_NAME=

# === Email ===
FROM_YOUR_EMAIL=
TO_COUNCIL_EMAIL=
# Optional, comma-separated
CC_EMAILS=
